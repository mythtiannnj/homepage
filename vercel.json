{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "index.js"
    },
    {
      "src": "/timeline",
      "dest": "index.js"
    },
    {
      "src": "/404",
      "dest": "/public/404.html"
    },
    {
      "src": "/500",
      "dest": "/public/500.html"
    },
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ]
}